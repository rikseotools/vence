# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
._*
*.pem

# debug
npm-debug.log*
yarn-debug.log*

# temporary scripts and import workdirs (never commit)
_tmp_*
_tmp_*/
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OpositaTest scraper
scripts/.opositatest-session/
debug-opositatest.*
debug-scraper.*
opositatest-*.json
preguntas-para-subir/

# TrustMRR scraper
scripts/.trustmrr-cookie

# Examen GVA OEP 2016 cuestionario escaneado pesado (12MB, sin OCR usable)
data/examenes-oficiales/auxiliar-administrativo-valencia/18-09-22 conv 9-16 OEP 2016/cuestionario_csif_scan.pdf

# sst
.sst

# open-next
.open-next

# Playwright E2E (Bloque 5 Fase E.4.1)
/test-results/
/playwright-report/
/playwright/.cache/

# Terraform state (live en S3 + DynamoDB lock — backend "s3" en versions.tf).
# Cualquier .tfstate local es solo backup temporal y NO debe entrar al repo.
backend/infra/terraform.tfstate
backend/infra/terraform.tfstate.backup
backend/infra/terraform.tfstate.local-backup-*
backend/infra/.terraform/
backend/infra/.terraform.lock.hcl
