{
  "name": "vence",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/check-help-articles.mjs; node scripts/sync-theme-names-from-bd.js; next build",
    "create-pwa-tables": "node scripts/create-pwa-tables.js",
    "db:check": "npx tsx scripts/check-schema-drift.ts",
    "db:clean": "node scripts/clean-database.js",
    "db:load-constitucion": "node scripts/load-constitucion.js",
    "db:load-constitucion-pdf": "node scripts/load-constitucion.js pdfs/constitucion-espanola.pdf",
    "db:pull": "drizzle-kit introspect",
    "audit:epigrafe": "node scripts/audit-epigrafe-scope.cjs",
    "ads:auth": "npx tsx --env-file=.env.local scripts/google-ads/get-refresh-token.ts",
    "ads:report": "npx tsx --env-file=.env.local scripts/google-ads/report.ts",
    "ads:campaign": "npx tsx --env-file=.env.local scripts/google-ads/campaign.ts",
    "ads:tracking": "npx tsx --env-file=.env.local scripts/google-ads/tracking.ts",
    "ads:roi": "npx tsx --env-file=.env.local scripts/google-ads/roi.ts",
    "dev": "next dev",
    "lint": "eslint .",
    "pre-commit": "npm run test:precommit && npm run test:unit && npm run lint",
    "prepare": "husky install",
    "setup-feedback-storage": "node scripts/setup-feedback-storage.js",
    "setup-storage-policies": "node scripts/setup-storage-policies.js",
    "start": "next start",
    "test": "jest",
    "test-image-upload": "node scripts/test-image-upload.js",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:components": "jest --testPathPattern='__tests__/components' --coverage",
    "test:coverage": "jest --coverage",
    "test:critical": "jest --testPathPattern='criticalValidations' --coverage",
    "test:full": "node scripts/validate-critical-paths.js",
    "test:hooks": "jest --testPathPattern='__tests__/hooks' --coverage",
    "test:integration": "jest --watchAll=false --passWithNoTests --testPathPattern='__tests__/(integration|perf|security|scraping|api/user-stats)'",
    "test:precommit": "jest --testPathPattern='precommit/criticalValidations' --passWithNoTests",
    "test:system": "node scripts/check-system.js",
    "test:unit": "jest --watchAll=false --passWithNoTests --testPathIgnorePatterns='/node_modules/' --testPathIgnorePatterns='__tests__/integration' --testPathIgnorePatterns='__tests__/perf' --testPathIgnorePatterns='__tests__/security' --testPathIgnorePatterns='__tests__/scraping' --testPathIgnorePatterns='__tests__/api/user-stats'",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:preview": "playwright test --project=preview-aws",
    "test:e2e:prod": "playwright test --project=prod-vercel",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install chromium",
    "gsc:keywords": "npx tsx --env-file=.env.local scripts/google-ads/gsc.ts",
    "gsc:seo": "npx tsx --env-file=.env.local scripts/google-ads/gsc.ts seo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-cloudwatch": "^3.1053.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@fingerprintjs/botd": "^2.0.0",
    "@heroicons/react": "^2.2.0",
    "@sentry/nextjs": "^10.32.1",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^7.4.0",
    "@supabase/supabase-js": "^2.50.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tinymce/tinymce-react": "^6.3.0",
    "@uiw/react-md-editor": "^4.0.8",
    "@upstash/redis": "^1.37.0",
    "canvas-confetti": "^1.9.4",
    "critters": "^0.0.23",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "google-ads-api": "^23.0.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.6",
    "openai": "^6.15.0",
    "pdfjs-dist": "^2.16.105",
    "playwright": "^1.56.1",
    "postgres": "^3.4.7",
    "puppeteer-real-browser": "^1.4.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.2.1",
    "remark-gfm": "^4.0.1",
    "resend": "^4.6.0",
    "server-only": "^0.0.1",
    "stripe": "^18.3.0",
    "svix": "^1.89.0",
    "telegram": "^2.26.22",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3",
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.1",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^29.7.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pg": "^8.16.3",
    "playwright-extra": "^4.3.6",
    "postcss": "^8.5.4",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tailwindcss": "^3.4.16",
    "typescript-eslint": "^8.59.4"
  },
  "description": "This is a [Next.js](https://nextjs.org) project bootstrapped with [`create-next-app`](https://github.com/vercel/next.js/tree/canary/packages/create-next-app).",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
