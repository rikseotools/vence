terraform {
  required_version = ">= 1.7"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }

  # Estado: para Etapa 1 se usa estado local (terraform.tfstate). Cuando haya
  # más de una persona aplicando, migrar a backend S3 + DynamoDB lock.
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      Project   = var.project
      ManagedBy = "terraform"
    }
  }
}
