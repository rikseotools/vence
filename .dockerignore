# Bloque 5 Fase E.1 — minimiza la image context que viaja al daemon Docker.
# Sin esto el build manda ~3GB al contexto (incluye .next, node_modules y
# datasets en data/).

# Dependencies (se reinstalan dentro del builder stage)
node_modules
.pnp
.pnp.js

# Next.js build output
.next
out

# Production build output
build
dist

# Testing
coverage
__tests__

# Misc
.DS_Store
*.pem
.vscode
.idea

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local env files (los provee ECS via SSM)
.env
.env*.local
.env.development
.env.test

# Vercel
.vercel

# Git
.git
.gitignore
.github

# Datasets de scraping y herramientas internas (no van a producción)
data/examenes-oficiales
data/scraping-cache
c1_t*
*.json.tmp
*.batch
backend
docs
scripts/smoke-*
scripts/debug-*
scripts/backfill-*

# Sentry source map artifacts (se suben en build via Sentry plugin)
.sentryclirc

# Backups
*.bak
*.tmp
*~
